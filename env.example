NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_SCRIPT="https://cloud.umami.is/script.js"
# -----------------------------------------------------------------------------
# OpenPanel Analytics (https://openpanel.dev)
# https://mksaas.com/docs/analytics#openpanel
# -----------------------------------------------------------------------------
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=""
# -----------------------------------------------------------------------------
# Plausible Analytics (https://plausible.io)
# https://mksaas.com/docs/analytics#plausible
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_PLAUSIBLE_SCRIPT="https://plausible.io/js/script.js"
# -----------------------------------------------------------------------------
# Ahrefs Analytics (https://ahrefs.com)
# https://mksaas.com/docs/analytics#ahrefs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AHREFS_WEBSITE_ID=""
# -----------------------------------------------------------------------------
# Seline Analytics
# https://mksaas.com/docs/analytics#seline
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SELINE_TOKEN=""
# -----------------------------------------------------------------------------
# DataFast Analytics (https://datafa.st)
# https://mksaas.com/docs/analytics#datafast
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=""
NEXT_PUBLIC_DATAFAST_DOMAIN=""
# -----------------------------------------------------------------------------
# PostHog Analytics (https://posthog.com)
# https://mksaas.com/docs/analytics#posthog
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
# -----------------------------------------------------------------------------
# Clarity Analytics (https://clarity.microsoft.com)
# https://mksaas.com/docs/analytics#clarity
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLARITY_PROJECT_ID=""


# -----------------------------------------------------------------------------
# Notification (Discord)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=""
# -----------------------------------------------------------------------------
# Notification (Feishu)
# -----------------------------------------------------------------------------
FEISHU_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# Affiliate
# https://mksaas.com/docs/affiliate
# -----------------------------------------------------------------------------
# Affonso
# https://affonso.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AFFILIATE_AFFONSO_ID=""
# -----------------------------------------------------------------------------
# PromoteKit
# https://www.promotekit.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AFFILIATE_PROMOTEKIT_ID=""

# -----------------------------------------------------------------------------
# Captcha (Cloudflare Turnstile)
# https://mksaas.com/docs/captcha
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# -----------------------------------------------------------------------------
# Crisp
# https://mksaas.com/docs/chat
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CRISP_WEBSITE_ID=""

# -----------------------------------------------------------------------------
# Cron Jobs
# https://mksaas.com/docs/cronjobs
# Used by protected cron routes such as:
# - /api/distribute-credits
# - /api/process-newsletter-jobs
# -----------------------------------------------------------------------------
CRON_JOBS_USERNAME=""
CRON_JOBS_PASSWORD=""

# -----------------------------------------------------------------------------
# Admin
# Comma-separated list of admin email addresses that bypass credit checks
# Example: "admin@example.com,dev@example.com"
# -----------------------------------------------------------------------------
ADMIN_EMAILS=""

# -----------------------------------------------------------------------------
# AI
# https://mksaas.com/docs/ai
# -----------------------------------------------------------------------------
# Google Gemini API (Image Generation)
# Get API key from https://aistudio.google.com/apikey
# Models: gemini-3-pro-image-preview (Nano Banana Pro), gemini-3.1-flash-image-preview (Nano Banana 2)
GEMINI_API_KEY=""
# Optional HTTPS proxy for Gemini-only outbound traffic
# Example: http://username:password@proxy.example.com:8080
GEMINI_HTTPS_PROXY=""
# Comma-separated allowlist for external image fetches used in multi-turn editing
# Example: "cdn.example.com,assets.example.com"
IMAGE_ALLOWED_FETCH_HOSTS=""
# Default model (optional): gemini-3-pro-image-preview | gemini-3.1-flash-image-preview
GEMINI_DEFAULT_MODEL="gemini-3-pro-image-preview"
# Legacy keys (kept for backwards compatibility)
AI_GATEWAY_API_KEY=""
FAL_API_KEY=""
FIREWORKS_API_KEY=""
OPENAI_API_KEY=""
REPLICATE_API_TOKEN=""
GOOGLE_GENERATIVE_AI_API_KEY=""
# Vertex AI Service Account (for Nano Banana Pro / Imagen 4)
# Paste the entire JSON content of your service account key file as a single line
# Example: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
DEEPSEEK_API_KEY=""
OPENROUTER_API_KEY=""

# -----------------------------------------------------------------------------
# Web Content Analyzer (Firecrawl)
# https://firecrawl.dev/
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=""
